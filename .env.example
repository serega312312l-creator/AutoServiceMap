# Скопіюй цей файл як .env і встав свої ключі
# Файл .env НЕ публікуй у git

GOOGLE_MAPS_API_KEY=встав_сюди_ключ_google_maps
GOOGLE_PLACES_API_KEY=встав_сюди_ключ_google_places
EAS_PROJECT_ID=

# Для EAS Build (хмарна збірка) — додай ті самі ключі на expo.dev:
# npx eas env:create --name GOOGLE_MAPS_API_KEY --value "AIza..." --environment preview
# npx eas env:create --name GOOGLE_PLACES_API_KEY --value "AIza..." --environment preview
# npx eas env:create --name GOOGLE_MAPS_API_KEY --value "AIza..." --environment production
# npx eas env:create --name GOOGLE_PLACES_API_KEY --value "AIza..." --environment production
